---
import SectionHeading from "../components/SectionHeading.astro";
import TimelineItem from "../components/TimelineItem.astro";
---

<section id="experience" class="py-16 lg:py-24 px-6 border-t border-line">
  <div class="max-w-content mx-auto">

    <div class="js-reveal">
      <SectionHeading segment="SM37 — Job Monitor" title="Experience" />
    </div>

    <div class="space-y-10 lg:space-y-16">

      <!-- Henkel — current, highest complexity -->
      <div class="js-reveal">
        <TimelineItem
          period="Jun 2025 — Present"
          role="Senior Integration Engineer"
          company="Henkel · Bengaluru, India"
          sublabel="DXV/EDI Customer Integrations Hub — GTC"
          bullets={[
            "Own end-to-end monitoring of EDI document flows across Henkel's global trading partner network via OpenText GXS, Seeburger B2B, and GIB; analyse middleware failures and resolve purchase order, ASN, and invoice errors before they escalate into business disruptions.",
            "Implement IDoc and EDI user exit fixes directly in SAP; diagnose and resolve partner profile, port, and RFC destination issues causing IDoc routing failures across SD, LE, and MM processes.",
            "Conduct root-cause analysis for recurring error patterns and implement permanent fixes; coordinate with business teams, customers, IT, and LSPs across WE, CEE, NA, LA, and APAC.",
          ]}
        />
      </div>

      <!-- Accenture Senior Analyst — SME, P1/P2, ABAP -->
      <div class="js-reveal" style="--delay: 60ms">
        <TimelineItem
          period="Dec 2023 — Jun 2025"
          role="Packaged App Development Senior Analyst"
          company="Accenture Services Pvt. Ltd · Bengaluru, India"
          sublabel="Client: Henkel International GmbH — FMO EDI Maintenance"
          bullets={[
            "Maintained EDI integrations via OpenText GXS (TGMS): managed 850, 856, 810, and XML mapping logic; resolved P1/P2 middleware incidents within SLA across WE, CEE, NA, LA, and APAC.",
            "Acted as SME for GXS mapping requirements; led knowledge transfer and built capability for new team members on GXS translation and monitoring workflows.",
            "Applied EDI user exit fixes in SAP ABAP (VOE2/VOE4) to resolve IDoc conversion and routing issues; designed monitoring workflows covering FTP/SFTP connectivity and message exchange tracking.",
          ]}
        />
      </div>

      <!-- Accenture Analyst — Seeburger, mapping, SAP setup -->
      <div class="js-reveal" style="--delay: 80ms">
        <TimelineItem
          period="Dec 2021 — Nov 2023"
          role="Packaged App Development Analyst"
          company="Accenture Services Pvt. Ltd · Bengaluru, India"
          sublabel="Client: Henkel International GmbH — FMO EDI Maintenance"
          bullets={[
            "Maintained EDI integrations via Seeburger B2B and GIB; implemented mapping changes per customer and business specifications and resolved trading partner document exchange failures.",
            "Created and maintained partner profiles, ports, and RFC destinations in SAP to route IDocs to Seeburger, OpenText GXS, and GIB middleware platforms.",
            "Conducted post-maintenance weekend testing and message validation to confirm mapping accuracy and system availability after changes went live.",
          ]}
        />
      </div>

      <!-- Accenture Associate — entry level monitoring and documentation -->
      <div class="js-reveal" style="--delay: 100ms">
        <TimelineItem
          period="Dec 2019 — Nov 2021"
          role="Packaged App Development Associate"
          company="Accenture Services Pvt. Ltd · Bengaluru, India"
          sublabel="Client: Henkel International GmbH — FMO EDI Maintenance"
          bullets={[
            "Monitored EDI and IDoc flows in Henkel's productive SAP environment; raised and tracked ServiceNow incidents for errors and resolved within defined SLA targets.",
            "Maintained trading partner profile documentation and activity logs to support team operations and SLA reporting.",
          ]}
        />
      </div>

      <!-- Impelsys Internship — C# -->
      <div class="js-reveal" style="--delay: 120ms">
        <TimelineItem
          period="Jul 2018 — Aug 2018"
          role="Intern"
          company="Impelsys · Mangaluru, India"
          bullets={[
            "Two-month final-year internship; introduced to enterprise application development using C#.",
          ]}
        />
      </div>

      <!-- Education -->
      <div class="js-reveal border-t border-line pt-8 lg:pt-12">
        <p class="font-display text-xs font-semibold text-cta uppercase tracking-widest mb-6">Education</p>
        <div class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-[14rem_1fr] gap-x-8 gap-y-1">
            <p class="font-display text-xs text-muted uppercase tracking-widest">2015 – 2019</p>
            <div>
              <p class="font-display text-sm font-semibold text-ink">B.E. Computer Science &amp; Engineering</p>
              <p class="font-body text-sm text-muted">Yenepoya Institute of Technology · Mangaluru, India</p>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-[14rem_1fr] gap-x-8 gap-y-1">
            <p class="font-display text-xs text-muted uppercase tracking-widest">2013 – 2015</p>
            <div>
              <p class="font-display text-sm font-semibold text-ink">PUC — PCMC</p>
              <p class="font-body text-sm text-muted">St. Raymond's College · Vamanjoor, Mangaluru</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
