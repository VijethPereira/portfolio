---
import SectionHeading from "../components/SectionHeading.astro";
---

<section id="projects" class="py-16 lg:py-24 px-6 border-t border-line">
  <div class="max-w-content mx-auto">

    <div class="js-reveal">
      <SectionHeading segment="SEGMENT 05" title="Side Projects" />
    </div>

    <div class="js-reveal max-w-2xl">
      <a
        href="https://quickmeasuretool.com"
        target="_blank"
        rel="noopener noreferrer"
        class="group block border border-line bg-surface hover:border-posted transition-colors duration-200"
      >
        <!-- Status bar -->
        <div class="border-b border-line px-6 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-posted flex-shrink-0" aria-hidden="true"></span>
            <span class="font-display text-xs uppercase tracking-widest text-muted">Live</span>
          </div>
          <span class="font-display text-xs text-muted group-hover:text-posted transition-colors">
            quickmeasuretool.com →
          </span>
        </div>

        <!-- Body -->
        <div class="p-6">
          <h3 class="font-display text-sm font-semibold text-ink group-hover:text-posted transition-colors leading-snug mb-3">
            Quick Measure — Free Online Measurement Tools
          </h3>
          <p class="font-body text-sm text-ink leading-relaxed mb-5">
            A suite of browser-based measurement and calculator tools — online ruler (cm/mm/in with
            screen calibration), protractor, slope &amp; grade, roof pitch, right triangle, and area
            calculator. No download, no sign-up. Built as a hobby project; live and actively growing.
          </p>

          <!-- Tool list -->
          <div class="flex flex-wrap gap-2 mb-5">
            {[
              "Online Ruler", "Protractor", "Slope & Grade",
              "Roof Pitch", "Right Triangle", "Area Calculator",
            ].map((tool) => (
              <span class="font-display text-xs uppercase tracking-wide border border-line bg-paper px-3 py-1">
                {tool}
              </span>
            ))}
          </div>

          <!-- Stack -->
          <p class="font-display text-xs text-muted uppercase tracking-widest">
            Astro &nbsp;·&nbsp; Tailwind CSS &nbsp;·&nbsp; Cloudflare Pages &nbsp;·&nbsp; Multi-language &nbsp;·&nbsp; Dark mode
          </p>
        </div>
      </a>
    </div>

  </div>
</section>
