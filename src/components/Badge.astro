---
interface Props {
  label: string;
  sublabel?: string;
}
const { label, sublabel } = Astro.props;
---

<div class="border border-line bg-surface px-4 py-3">
  <div class="flex items-start gap-3">
    <span class="font-display text-posted flex-shrink-0 mt-0.5 text-sm" aria-hidden="true">★</span>
    <div>
      <p class="font-display text-xs font-semibold text-ink uppercase tracking-wide">{label}</p>
      {sublabel && (
        <p class="font-body text-xs text-muted mt-0.5 leading-snug">{sublabel}</p>
      )}
    </div>
  </div>
</div>
