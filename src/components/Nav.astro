---
const links = [
  { href: "#work",       label: "Work"       },
  { href: "#about",      label: "About"      },
  { href: "#skills",     label: "Skills"     },
  { href: "#projects",   label: "Projects"   },
  { href: "#contact",    label: "Contact"    },
];
---

<header class="sticky top-0 z-50 bg-paper/90 backdrop-blur-sm border-b border-line">
  <nav
    class="max-w-content mx-auto px-6 h-14 flex items-center justify-between"
    aria-label="Site navigation"
  >

    <!-- Wordmark -->
    <a
      href="/"
      class="font-display text-sm font-black uppercase tracking-tight text-ink hover:text-posted transition-colors duration-200 cursor-pointer"
    >
      VP
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="font-display text-xs font-medium uppercase tracking-widest text-muted hover:text-ink transition-colors duration-200 cursor-pointer"
          >
            {label}
          </a>
        </li>
      ))}

      <li>
        <button
          id="theme-toggle"
          class="text-muted hover:text-ink transition-colors duration-200 inline-flex items-center justify-center min-h-[44px] min-w-[44px] cursor-pointer"
          aria-label="Switch to dark mode"
        >
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
      </li>

      <li>
        <a
          href="/resume.pdf"
          target="_blank"
          rel="noopener"
          class="font-display text-xs font-bold uppercase tracking-widest bg-cta text-white px-4 py-2.5 hover:opacity-90 transition-opacity duration-200 cursor-pointer inline-flex items-center"
        >
          Resume
        </a>
      </li>
    </ul>

    <!-- Mobile controls -->
    <div class="flex md:hidden items-center gap-3">
      <button
        id="theme-toggle-mobile"
        class="text-muted hover:text-ink transition-colors duration-200 inline-flex items-center justify-center min-h-[44px] min-w-[44px] cursor-pointer"
        aria-label="Switch to dark mode"
      >
        <svg id="icon-moon-mobile" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="icon-sun-mobile" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
      <button
        id="nav-toggle"
        class="font-display text-xs font-medium uppercase tracking-widest text-muted hover:text-ink transition-colors duration-200 cursor-pointer"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle navigation"
      >
        Menu
      </button>
    </div>

  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-paper border-t border-line px-6 pb-6"
  >
    <ul class="flex flex-col gap-5 list-none m-0 p-0 pt-5">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="font-display text-sm font-medium uppercase tracking-widest text-muted hover:text-ink transition-colors duration-200 block cursor-pointer"
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="/resume.pdf"
          target="_blank"
          rel="noopener"
          class="font-display text-sm font-bold uppercase tracking-widest bg-cta text-white px-5 py-2.5 inline-block hover:opacity-90 transition-opacity duration-200 cursor-pointer"
        >
          Resume
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const navToggle = document.getElementById("nav-toggle");
  const menu      = document.getElementById("mobile-menu");

  navToggle?.addEventListener("click", () => {
    const open = navToggle.getAttribute("aria-expanded") === "true";
    navToggle.setAttribute("aria-expanded", String(!open));
    menu?.classList.toggle("hidden");
  });

  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      menu.classList.add("hidden");
      navToggle?.setAttribute("aria-expanded", "false");
    })
  );

  const moonD = document.getElementById("icon-moon");
  const sunD  = document.getElementById("icon-sun");
  const moonM = document.getElementById("icon-moon-mobile");
  const sunM  = document.getElementById("icon-sun-mobile");
  const btnD  = document.getElementById("theme-toggle");
  const btnM  = document.getElementById("theme-toggle-mobile");

  function syncIcons(isDark: boolean) {
    moonD?.classList.toggle("hidden", isDark);
    sunD?.classList.toggle("hidden", !isDark);
    moonM?.classList.toggle("hidden", isDark);
    sunM?.classList.toggle("hidden", !isDark);
    const label = isDark ? "Switch to light mode" : "Switch to dark mode";
    btnD?.setAttribute("aria-label", label);
    btnM?.setAttribute("aria-label", label);
  }

  function applyTheme(dark: boolean) {
    document.documentElement.classList.toggle("dark", dark);
    localStorage.setItem("theme", dark ? "dark" : "light");
    syncIcons(dark);
  }

  syncIcons(document.documentElement.classList.contains("dark"));
  btnD?.addEventListener("click", () => applyTheme(!document.documentElement.classList.contains("dark")));
  btnM?.addEventListener("click", () => applyTheme(!document.documentElement.classList.contains("dark")));
</script>
