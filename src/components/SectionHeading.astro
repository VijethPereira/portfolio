---
interface Props {
  segment: string;
  title: string;
}

const { segment, title } = Astro.props;
---

<div class="mb-10 lg:mb-14">
  <p class="font-display text-xs font-semibold text-cta uppercase tracking-widest mb-3">{segment}</p>
  <h2 class="font-display text-3xl sm:text-4xl font-black text-ink tracking-tight leading-tight">{title}</h2>
</div>
