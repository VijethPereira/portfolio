---
interface Props {
  segment: string; // e.g. "SEGMENT 01"
  title: string;   // e.g. "About"
}

const { segment, title } = Astro.props;
---

<div class="mb-8 lg:mb-12">
  <p class="font-display text-xs text-muted uppercase tracking-widest mb-3">{segment}</p>
  <h2 class="font-display text-3xl font-semibold text-ink">{title}</h2>
</div>
