---
interface Props {
  period: string;
  role: string;
  company: string;
  sublabel?: string;
  bullets: string[];
}
const { period, role, company, sublabel, bullets } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-[14rem_1fr] gap-x-8 gap-y-3">
  <div class="md:pt-0.5">
    <p class="font-display text-xs text-muted uppercase tracking-widest leading-relaxed">{period}</p>
  </div>
  <div>
    <h3 class="font-display text-base font-semibold text-ink">{role}</h3>
    <p class="font-display text-sm text-muted mt-1">{company}</p>
    {sublabel && (
      <p class="font-display text-xs text-muted mt-0.5">{sublabel}</p>
    )}
    <ul class="mt-4 space-y-2 list-none p-0 m-0">
      {bullets.map((b) => (
        <li class="font-body text-sm text-ink flex gap-3 leading-relaxed">
          <span class="text-posted flex-shrink-0 mt-0.5" aria-hidden="true">—</span>
          <span>{b}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
