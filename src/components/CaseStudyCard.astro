---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"work">;
}

const { entry } = Astro.props;
const { title, challenge, approach, outcome, status } = entry.data;
---

<article class="group border border-line bg-surface flex flex-col h-full overflow-hidden hover:border-cta hover:-translate-y-1 hover:shadow-[0_16px_40px_rgba(0,0,0,0.10),0_0_24px_rgba(37,99,235,0.09)] transition-[transform,box-shadow,border-color] duration-300">

  <!-- Blue accent bar sweeps on hover -->
  <div class="h-0.5 bg-cta w-0 group-hover:w-full transition-all duration-500"></div>

  <!-- Status bar -->
  <div class="px-6 pt-5 pb-4 border-b border-line flex items-center gap-2">
    <span
      class:list={[
        "w-1.5 h-1.5 rounded-full flex-shrink-0",
        status === "posted" ? "bg-posted" : "bg-pending",
      ]}
      aria-hidden="true"
    />
    <span class="font-display text-xs font-medium uppercase tracking-widest text-muted">
      {status}
    </span>
  </div>

  <!-- Body -->
  <div class="p-6 flex flex-col gap-5 flex-1">
    <h3 class="font-display text-sm font-bold text-ink group-hover:text-cta transition-colors duration-300 leading-snug">
      {title}
    </h3>

    <dl class="space-y-4 flex-1">
      <div>
        <dt class="font-display text-xs font-semibold text-muted uppercase tracking-widest mb-1.5">Challenge</dt>
        <dd class="font-body text-sm text-ink leading-relaxed">{challenge}</dd>
      </div>
      <div>
        <dt class="font-display text-xs font-semibold text-muted uppercase tracking-widest mb-1.5">Approach</dt>
        <dd class="font-body text-sm text-ink leading-relaxed">{approach}</dd>
      </div>
      <div>
        <dt class="font-display text-xs font-semibold text-muted uppercase tracking-widest mb-1.5">Outcome</dt>
        <dd class="font-body text-sm font-semibold text-posted leading-relaxed">{outcome}</dd>
      </div>
    </dl>
  </div>

</article>
