---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Vijeth Pereira — Senior Integration Engineer at Henkel",
  description = "Senior Integration Engineer at Henkel (DXV/EDI Customer Integrations Hub · GTC) with 5+ years delivering B2B EDI solutions — X12, EDIFACT, SAP IDocs, ALE, OpenText GXS, Seeburger B2B. Based in Bengaluru, India.",
} = Astro.props;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Vijeth Pereira",
  "jobTitle": "Senior Integration Engineer",
  "email": "pereiravijeth@gmail.com",
  "url": "https://www.linkedin.com/in/vijeth-pereira/",
  "knowsAbout": ["SAP EDI", "ALE", "IDoc", "ANSI X12", "EDIFACT", "OpenText GXS", "Seeburger B2B", "ABAP"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Bengaluru",
    "addressCountry": "IN",
  },
  "worksFor": {
    "@type": "Organization",
    "name": "Henkel",
  },
  "award": ["Henkel Sieger Award — Delivery Champion"],
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <!-- Preconnect for fast font load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Archivo (headings) + Space Grotesk (body) — design system typography -->
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={jsonLd} />

    <!-- Theme init — runs before paint to prevent flash -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (saved === "dark" || (!saved && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <!-- Skip link — keyboard accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:z-[200] focus:top-4 focus:left-4 focus:px-5 focus:py-3 focus:bg-cta focus:text-white focus:font-display focus:text-sm focus:font-bold focus:outline-none"
    >
      Skip to main content
    </a>

    <!-- Ambient background -->
    <div aria-hidden="true" class="fixed inset-0 -z-10 pointer-events-none">
      <div id="bg-layer-1" class="absolute inset-0"></div>
      <div id="bg-layer-2" class="absolute inset-0"></div>
    </div>

    <main id="main-content">
      <slot />
    </main>

    <script>
      // ── Scroll-reveal (IntersectionObserver) ──
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const mark = (el: Element) => el.classList.add("revealed");
      const selectors = ".js-reveal, .js-reveal-left, .js-reveal-scale";

      if (reduced) {
        document.querySelectorAll(selectors).forEach(mark);
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                mark(e.target);
                observer.unobserve(e.target);
              }
            });
          },
          { threshold: 0.06, rootMargin: "0px 0px -30px 0px" }
        );
        document.querySelectorAll(selectors).forEach((el) => observer.observe(el));
      }

    </script>
  </body>
</html>
